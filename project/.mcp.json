{
  "mcpServers": {
    "Salesforce-DX": {
      "command": "npx",
      "args": [
        "-y",
        "@salesforce/mcp@latest",
        "--orgs",
        "DEFAULT_TARGET_ORG",
        "--toolsets",
        "orgs,metadata,data,users,code-analysis,testing",
        "--tools",
        "run_apex_test,run_soql_query,deploy_metadata,retrieve_metadata",
        "--allow-non-ga-tools"
      ]
    }
  }
}
