<?xml version='1.0' encoding='UTF-8'?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Contact_Info</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISBLANK(Contact__c), OR(ISBLANK(Mobile__c), ISBLANK(Email__c)))</errorConditionFormula>
    <errorMessage>Must enter Contact or (Mobile + Email)</errorMessage>
</ValidationRule>